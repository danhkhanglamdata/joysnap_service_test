{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {},
            "disabled": false,
            "autoApprove": [
                "get-library-docs",
                "resolve-library-id"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "env": {},
            "disabled": false,
            "autoApprove": [
                "sequentialthinking"
            ]
        },
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ],
            "disabled": false
        },
        "puppeteer": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ],
            "disabled": false,
            "autoApprove": [
                "puppeteer_navigate",
                "puppeteer_screenshot",
                "puppeteer_click",
                "puppeteer_fill",
                "puppeteer_evaluate"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest"
            ],
            "disabled": false
        },
        "magic": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@21st-dev/magic@latest"
            ],
            "env": {
                "API_KEY": "${MAGIC_21ST_DEV_API_KEY}"
            },
            "disabled": false
        },
        "perplexity-ask": {
            "command": "npx",
            "args": [
                "-y",
                "server-perplexity-ask"
            ],
            "env": {
                "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
            },
            "disabled": false,
            "autoApprove": [
                "perplexity_ask"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ],
            "disabled": false
        },
        "repomix": {
            "command": "npx",
            "args": [
                "-y",
                "repomix",
                "--mcp"
            ],
            "disabled": false
        },
        "knowledge-graph": {
            "type": "sse",
            "url": "http://localhost:27495/mcp/sse",
            "approvedTools": [
                "list_projects",
                "search_codebase_definitions",
                "index_project",
                "get_references",
                "read_definitions",
                "get_definition",
                "repo_map"
            ],
            "disabled": false
        },
        "supabase": {
            "type": "http",
            "url": "https://mcp.supabase.com/mcp",
            "env": {
                "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
            },
            "disabled": false,
            "autoApprove": []
        },
        "vercel": {
            "command": "npx",
            "args": [
                "-y",
                "@robinson_ai_systems/vercel-mcp"
            ],
            "env": {
                "VERCEL_TOKEN": "${VERCEL_TOKEN}",
                "VERCEL_TEAM_ID": "${VERCEL_TEAM_ID}"
            },
            "disabled": false,
            "autoApprove": [
                "list-deployments",
                "get-deployment",
                "list-projects"
            ]
        },
        "morph-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@morphllm/morphmcp"
            ],
            "env": {
                "MORPH_API_KEY": "${MORPH_API_KEY}",
                "ENABLED_TOOLS": "edit_file,warpgrep_codebase_search",
                "WORKSPACE_MODE": "false",
                "DEBUG": "true"
            },
            "disabled": true
        },
        "toonify": {
            "type": "stdio",
            "command": "toonify-mcp",
            "args": [],
            "env": {},
            "disabled": true
        }
    }
}
