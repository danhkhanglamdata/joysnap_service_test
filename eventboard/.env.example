# EventBoard — Environment Variables
# Copy this file to .env and fill in your values.
# Set these in Vercel Dashboard for production.

# ─────────────────────────────────────────────────────────
# SUPABASE (backend + frontend)
# ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # backend only — never expose to frontend!

# ─────────────────────────────────────────────────────────
# FRONTEND (Vite — prefix VITE_ to expose to browser)
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────
APP_URL=https://your-app.vercel.app   # Used for QR code generation
ENVIRONMENT=development               # development | production
