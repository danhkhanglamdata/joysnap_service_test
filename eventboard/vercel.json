{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ],
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ]
}
