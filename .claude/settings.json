{
  "env": {},
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(pip:*)",
      "Bash(poetry:*)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(node:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(tsc:*)",
      "Bash(docker:*)",
      "Bash(gh:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/env.php*)",
      "Read(**/*.pem)",
      "Read(**/.ssh/**)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Write(**/.env*)",
      "Write(**/env.php*)",
      "Write(**/*.pem)",
      "Write(**/.ssh/**)",
      "Write(**/*.key)",
      "Write(**/secrets/**)",
      "Write(**/credentials/**)",
      "Write(**/.aws/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'HUD_ROOT=\"${CLAUDE_HUD_ROOT:-$HOME/.claude/plugins/cache/claude-hud/claude-hud}\"; HUD_DIR=\"$(ls -td \"$HUD_ROOT\"/*/ 2>/dev/null | head -1)\"; [ -n \"$HUD_DIR\" ] && bun \"${HUD_DIR}src/index.ts\" || true'"
  },
  "fileSuggestion": {
    "type": "command",
    "command": "./.claude/file-suggestion.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "claude-hud@claude-hud": true,
    "ralph-loop@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  }
}